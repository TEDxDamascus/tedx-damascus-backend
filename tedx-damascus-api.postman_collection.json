              "raw": "{\n  \"title\": {\n    \"ar\": \"مستقبل الأفكار\",\n    \"en\": \"The Future of Ideas\"\n  },\n  \"description\": {\n    \"ar\": \"مقالة قصيرة عن الأفكار التي تشكل المستقبل\",\n    \"en\": \"A short article about ideas shaping the future\"\n  },\n  \"content\": {\n    \"ar\": \"هذا محتوى تجريبي للمقال باللغة العربية.\",\n    \"en\": \"This is sample blog content in English.\"\n  },\n  \"status\": \"published\",\n  \"publishedAt\": \"2026-04-22T10:00:00.000Z\",\n  \"category_id\": \"{{category_id}}\",\n  \"read_time\": 4,\n  \"meta_title\": {\n    \"ar\": \"مستقبل الأفكار | TEDx Damascus\",\n    \"en\": \"The Future of Ideas | TEDx Damascus\"\n  },\n  \"meta_description\": {\n    \"ar\": \"وصف SEO عربي للمقال\",\n    \"en\": \"English SEO description for the blog\"\n  },\n  \"meta_keywords\": {\n    \"ar\": \"أفكار, ابتكار, مستقبل\",\n    \"en\": \"ideas, innovation, future\"\n  },\n  \"canonical_url\": \"https://tedxdamascus.com/blogs/the-future-of-ideas\",\n  \"og_title\": {\n    \"ar\": \"مستقبل الأفكار\",\n    \"en\": \"The Future of Ideas\"\n  },\n  \"og_description\": {\n    \"ar\": \"وصف Open Graph عربي\",\n    \"en\": \"English Open Graph description\"\n  },\n  \"gallery\": []\n}"
            },
