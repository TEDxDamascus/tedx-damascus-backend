              "mode": "raw",
              "raw": "{\n  \"title\": {\n    \"ar\": \"عنوان عربي\",\n    \"en\": \"English Title\"\n  },\n  \"content\": {\n    \"ar\": \"محتوى عربي\",\n    \"en\": \"English content\"\n  },\n  \"status\": \"draft\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/blogs",
              "host": ["{{base_url}}"],
              "path": ["blogs"]
            }
          },
          "response": []
